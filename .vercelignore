# Shared ignore for Vercel uploads. IMPORTANT: next-app must NOT be listed here —
# for Git deployments Vercel applies this file at upload time, before the
# Root Directory setting, so excluding next-app breaks the backend project
# ("No Next.js version detected"). The storefront project instead blocks
# public access to /next-app/* via the redirect in vercel.json.
tools
*.ps1
.claude
docs
