# DOODLY — environment (copy to .env.local and fill in)

# Site / deployment
# Your production domain (no trailing slash). Used for metadata, canonical
# URLs, sitemap, robots and OG tags. Replace before going live.
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Analytics (all optional — nothing loads unless set)
NEXT_PUBLIC_GA_ID=""                       # Google Analytics 4  (G-XXXXXXXXXX)
NEXT_PUBLIC_CLARITY_ID=""                  # Microsoft Clarity   (xxxxxxxxxx)
NEXT_PUBLIC_META_PIXEL_ID=""               # Meta / Facebook Pixel
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""    # Google Search Console (meta tag value)

# Supabase (Postgres + Auth)
DATABASE_URL="postgresql://...pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."

# Auth.js (NextAuth v5) — REQUIRED. Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""
# Set true when NOT on Vercel (self-hosted / preview) so the request host is trusted.
AUTH_TRUST_HOST="true"

# Initial Super Admin, seeded by `npm run db:seed`. Change the password after first login.
SEED_SUPERADMIN_EMAIL="admin@doodly.test"
SEED_SUPERADMIN_PASSWORD="change-me-strong"
# Optional sender for the password-reset email; without RESEND_API_KEY the link is logged to the server console.
EMAIL_FROM="DOODLY <noreply@yourdomain.com>"

# Razorpay (server secrets — NEVER expose the secret/webhook to the browser)
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."
# Recurring auto-pay: a Razorpay plan_id per subscription plan (create in dashboard).
RAZORPAY_PLAN_IDS='{"p7":"plan_xxx","p30":"plan_yyy","p90":"plan_zzz"}'
# Public key id — safe to ship to the browser (Checkout needs it).
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_..."

# Google Maps
# Browser key (restrict by HTTP referrer in the Cloud console). Enable: Maps
# JavaScript API, Places API, Geocoding API, Directions API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="..."
# Server key (IP-restricted) for server-side Geocoding / Directions / Distance Matrix.
GOOGLE_MAPS_API_KEY="..."

# Other integrations
CLOUDINARY_URL="cloudinary://..."

# ---- Transactional notifications (SMS / WhatsApp / Email) ----------------
# Every channel is optional + fallback-safe: with no keys, notifications stay
# in-app only and nothing breaks. Set what you have and those channels go live.
#
# EMAIL — Resend (already used for password reset). Verify your sending domain.
RESEND_API_KEY="..."
# SMS + WhatsApp — Twilio (SMS via TWILIO_SMS_FROM, WhatsApp via TWILIO_WHATSAPP_FROM).
# TWILIO_SMS_FROM may be a purchased number (+1XXX) or a Messaging Service SID (MGxxxx).
TWILIO_ACCOUNT_SID="..."
TWILIO_AUTH_TOKEN="..."
TWILIO_SMS_FROM="+1XXXXXXXXXX"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# SMS — MSG91 alternative (India). Used only if Twilio SMS is not configured.
# MSG91_AUTH_KEY="..."
# MSG91_SENDER_ID="DOODLY"
# MSG91_ROUTE="4"          # 4 = transactional
#
# Secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>` to
# /api/cron/notifications (the drain sweep). Set it and add the same value in
# Vercel → Project → Settings → Environment Variables.
CRON_SECRET="..."
