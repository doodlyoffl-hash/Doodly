model QualityConfig {
  id           String   @id @default("singleton")
  minFatPct    Float    @default(6.0)
  minSnfPct    Float    @default(8.5)
  tempMinC     Float    @default(2.0)
  tempMaxC     Float    @default(6.0)
  densityMin   Float    @default(26.0)              // lactometer reading
  densityMax   Float    @default(32.0)
  updatedAt    DateTime @default(now()) @updatedAt
  updatedBy    String?
}

model QualityTest {
  id            String      @id @default(cuid())
  procurementId String      @unique
  procurement   Procurement @relation(fields: [procurementId], references: [id])
  fatPct        Float
  snfPct        Float
  lactometer    Float
  temperatureC  Float
  passed        Boolean
  rejectReason  String?
  labReportUrl  String?
  testedAt      DateTime    @default(now())
}

// ----------------------------------------------------------------
// INVENTORY
// ----------------------------------------------------------------
model InventoryItem {
  id          String   @id @default(cuid())
  sku         String   @unique                     // "MILK_RAW","BOTTLE_1L","CAP","LABEL"
  name        String
  unit        String                               // "litre","piece"
