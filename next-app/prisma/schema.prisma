  deletedAt   DateTime?                            // soft-delete (restorable)
  notes       String?
  distanceKm  Float?                               // computed on optimize (haversine over stops)
  durationMin Int?                                 // estimated travel time
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  deliveries  Delivery[]
}

// ----------------------------------------------------------------
// GROWTH: referral, loyalty, coupons, reviews
// ----------------------------------------------------------------
enum CouponDiscountType {
  PERCENT
  FLAT
}
enum CouponEligibility {
  ALL
  FIRST_ORDER
  SPECIFIC
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  name           String?
  description    String?
  campaignName   String?                                       // groups coupons into a campaign
  discountType   CouponDiscountType @default(PERCENT)
  discountBps    Int?                                          // % off in basis points (PERCENT)
  flatPaise      Int?                                          // flat ₹ off in paise (FLAT)
  maxDiscountPaise Int?                                        // cap on a % discount
  minOrderPaise  Int                @default(0)                // minimum cart value to apply
  firstOrderOnly Boolean            @default(false)
  eligibility    CouponEligibility  @default(ALL)
  eligibleUserIds         String[]                             // for SPECIFIC customer coupons
  applicableProductSlugs  String[]                             // empty = all products
  applicableCategorySlugs String[]
  applicablePlanSlugs     String[]                             // subscription-plan restriction
  perCustomerLimit Int?                                        // max redemptions per customer
  maxRedemptions Int?                                          // total redemption cap
  redeemed       Int                @default(0)                // denormalised counter
  startsAt       DateTime?                                     // scheduled start (null = live now)
  expiresAt      DateTime?
  active         Boolean            @default(true)
  createdById    String?
  deletedAt      DateTime?                                     // soft delete
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt
  redemptions    CouponRedemption[]
  @@index([active, deletedAt])
}

// Offers = campaign-driven promotions (typed, prioritized, often codeless / auto-applied).
// Reuses the Coupon discount enums + the pure coupon engine (validate/computeDiscount);
// only the entity + type/priority/lifecycle are offer-specific. Future: BOGO/bundle maths,
// flash sales, personalised + AI-recommended offers hang off offerType + priority.
enum OfferType {
  PERCENT
  FLAT
  BOGO
  BUNDLE
  SUBSCRIPTION
  FIRST_ORDER
  SEASONAL
  FESTIVAL
  LIMITED_TIME
  CUSTOMER_SPECIFIC
  PRODUCT_SPECIFIC
  CATEGORY_SPECIFIC
  CASHBACK
}
enum OfferState {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

model Offer {
  id             String             @id @default(cuid())
  name           String
  code           String?            @unique                 // optional — codeless offers auto-apply
  description    String?
  campaignName   String?
  offerType      OfferType          @default(PERCENT)
  discountType   CouponDiscountType @default(PERCENT)       // reuse coupon discount primitive
  discountBps    Int?
  flatPaise      Int?
  maxDiscountPaise Int?
  minOrderPaise  Int                @default(0)
  eligibility    CouponEligibility  @default(ALL)           // reuse coupon eligibility primitive
  eligibleUserIds         String[]
  applicableProductSlugs  String[]
  applicableCategorySlugs String[]
  applicablePlanSlugs     String[]
  perCustomerLimit Int?
  maxRedemptions Int?
  redeemed       Int                @default(0)
  priority       Int                @default(0)             // higher wins when offers compete
  startsAt       DateTime?
  expiresAt      DateTime?
  state          OfferState         @default(DRAFT)         // draft → active ⇄ paused → archived
  bannerText     String?                                    // marketing banner integration (future-ready)
  bannerImageUrl String?
  createdById    String?
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt
  redemptions    OfferRedemption[]
  @@index([state, deletedAt])
  @@index([priority])
}

model OfferRedemption {
  id              String   @id @default(cuid())
  offerId         String
  offer           Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  userId          String?
  orderId         String?  @unique                          // idempotent per order
  discountPaise   Int
  orderTotalPaise Int?
  createdAt       DateTime @default(now())
  @@index([offerId, createdAt])
  @@index([userId])
}

// Every coupon application is recorded here → usage history, per-customer limits,
// revenue-generated analytics and idempotency (one redemption per order).
model CouponRedemption {
  id              String   @id @default(cuid())
  couponId        String
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId          String?
  orderId         String?  @unique                             // idempotent per order
  discountPaise   Int
  orderTotalPaise Int?
  createdAt       DateTime @default(now())
  @@index([couponId, createdAt])
  @@index([userId])
}

model Review {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  target      String                                 // order label (products purchased)
  productSlug String?                                // primary product reviewed (analytics / filters)
  title       String?                                // optional review headline
  rating      Int                                    // 1..5
  comment     String?
  orderId     String?   @unique                      // verified review: the delivered order it reviews (one review per order)
  // ---- moderation (public site shows ONLY status=APPROVED && rating=5 && orderId set) ----
  status      String    @default("PENDING")          // PENDING | APPROVED | REJECTED | HIDDEN
  featured    Boolean   @default(false)              // featured reviews sort first publicly
  reply       String?                                // admin/support reply (internal + shown to the customer)
  repliedAt   DateTime?
  moderatedBy String?                                // admin role/id snapshot
  moderatedAt DateTime?
  createdAt   DateTime  @default(now())
  @@index([userId, createdAt])
  @@index([status, rating, featured, createdAt])     // public listing + admin filters
}

// ----------------------------------------------------------------
// NOTIFICATIONS  (SMS / WhatsApp / Push / Email)
// ----------------------------------------------------------------
model Notification {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  channel   NotifChannel
  title     String
  body      String
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime     @default(now())
  // External dispatch tracking (SMS/WhatsApp/Email). PENDING rows are picked
  // up by the drain; inline dispatch stamps these directly on create.
  dispatchedAt   DateTime?
  providerStatus String    @default("PENDING")   // PENDING | SENT | SKIPPED | FAILED
  providerRef    String?                          // primary external message id
  providerLog    String?                          // compact per-channel result JSON
  // Marketing campaign link — this row IS the per-recipient delivery log for a
  // NotificationCampaign (null for transactional notifications). Powers real
  // per-campaign delivery logs + analytics + retry.
  campaignId     String?
  retryCount     Int       @default(0)
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([providerStatus])
  @@index([campaignId])
}

// ================================================================
// CUSTOMER CRM (Commerce → Customers)
// A customer = a User with role = CUSTOMER. These tables add the
// CRM layer on top: staff notes, an append-only activity / status
// timeline (audit), and per-customer preferences. Everything else
// (addresses, wallet txns, referrals, orders…) reuses existing
// models via the User relations.
// ================================================================
model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  byId      String?
  byRole    String?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

// Activity log + status history + audit trail for a customer.
model CustomerEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String                                // CREATED|UPDATED|STATUS|ADDRESS|WALLET|SUBSCRIPTION|REFERRAL|PASSWORD|PREFERENCE|NOTE|NOTIFY|EXPORT
  summary   String
  detail    Json?                                 // { field: { from, to } } change set
  byId      String?
  byRole    String?
  ip        String?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

model CustomerPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  emailOptIn        Boolean  @default(true)
  smsOptIn          Boolean  @default(false)
  whatsappOptIn     Boolean  @default(true)    // transactional WhatsApp defaults ON (customer can opt out in settings)
  pushOptIn         Boolean  @default(true)
  marketingOptIn    Boolean  @default(true)
  language          String   @default("en")
  preferredSlot     String?
  assignedExecutive String?                        // CRM delivery-executive assignment (name snapshot)
  updatedAt         DateTime @default(now()) @updatedAt
}

// ----------------------------------------------------------------
// CMS  (editable homepage content, banners, FAQs, testimonials)
// ----------------------------------------------------------------
model CmsBlock {
  id        String   @id @default(cuid())
  key       String   @unique                       // "hero","banner.1","faq.list"
  type      String                                 // "hero","banner","faq","testimonial","blog"
  data      Json                                   // flexible content payload
  published Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ================================================================
// AUTO DELIVERY ASSIGNMENT SYSTEM
// Capacity-aware distribution of deliveries to executives (45 bottles/
// trip), overflow queue, return-trip continuation, full audit trail.
// ================================================================

// Lifecycle of a single delivery's assignment to an executive.
enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  OUT_FOR_DELIVERY
  COMPLETED
  RETURNED_TO_DAIRY
  CANCELLED
  REASSIGNED
}

// Live availability of a delivery executive. Only AVAILABLE / RETURNED_TO_DAIRY can take new work.
enum ExecAvailability {
  AVAILABLE
  ASSIGNED
  ACCEPTED
  OUT_FOR_DELIVERY
  COMPLETED
  RETURNED_TO_DAIRY
  OFFLINE
  BREAK
}

// A queued (unassigned) delivery waiting for capacity.
enum QueueStatus {
  PENDING
  ASSIGNED
  CANCELLED
}

// A trip = one batch an executive carries out and brings back.
enum TripStatus {
  ASSIGNED
  ACCEPTED
  OUT_FOR_DELIVERY
  COMPLETED
  RETURNED_TO_DAIRY
}

// Every assignment mutation is logged for a complete audit trail.
enum AssignmentAction {
  AUTO_ASSIGN
  MANUAL_ASSIGN
  REASSIGN
  UNASSIGN
  MOVE
  QUEUE
  DEQUEUE
  LOCK
  UNLOCK
  STATUS_CHANGE
  RETURN_TRIP
  FAIL
  RETRY
}

// Per-executive carrying capacity (default 45 bottles/trip). Editable by admin.
model DeliveryCapacity {
  id         String   @id @default(cuid())
  driverId   String   @unique
  driver     Driver   @relation(fields: [driverId], references: [id])
  maxBottles Int      @default(45)
  active     Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

// Live executive availability + current trip load (one row per executive).
model ExecutiveStatus {
  id              String           @id @default(cuid())
  driverId        String           @unique
  driver          Driver           @relation(fields: [driverId], references: [id])
  availability    ExecAvailability @default(AVAILABLE)
  currentTripId   String?
  assignedBottles Int              @default(0)        // bottles currently loaded for the live trip
  lastChangedAt   DateTime         @updatedAt
  @@index([availability])
}

// A delivery assigned to an executive on a trip. deliveryId is UNIQUE → a
// delivery can never be double-assigned (DB-enforced, race-safe).
model DeliveryAssignment {
  id          String           @id @default(cuid())
  deliveryId  String           @unique
  delivery    Delivery         @relation(fields: [deliveryId], references: [id])
  driverId    String
  driver      Driver           @relation(fields: [driverId], references: [id])
  tripId      String?
  trip        TripHistory?     @relation(fields: [tripId], references: [id])
  slot        String
  date        DateTime
  bottles     Int
  status      AssignmentStatus @default(ASSIGNED)
  sequence    Int?                                    // stop order within the trip
  area        String?
  zoneId      String?
  locked      Boolean          @default(false)        // admin lock → excluded from auto reassignment
  assignedAt  DateTime         @default(now())
  acceptedAt  DateTime?
  completedAt DateTime?
  @@index([driverId, date, slot])
  @@index([status, slot, date])
  @@index([zoneId, area])
}

// Overflow: deliveries that couldn't be assigned yet. deliveryId UNIQUE → no dup queue rows.
model AssignmentQueue {
  id         String      @id @default(cuid())
  deliveryId String      @unique
  delivery   Delivery    @relation(fields: [deliveryId], references: [id])
  slot       String
  date       DateTime
  bottles    Int
  area       String?
  zoneId     String?
  status     QueueStatus @default(PENDING)
  priority   Int         @default(0)                  // higher = assigned sooner (FIFO tiebreak by createdAt)
  reason     String?                                  // "capacity_full" | "no_executive" | "oversize"
  createdAt  DateTime    @default(now())
  assignedAt DateTime?
  @@index([status, slot, date, priority])
}

// A trip an executive runs (a batch up to capacity), then returns to dairy.
model TripHistory {
  id           String               @id @default(cuid())
  driverId     String
  driver       Driver               @relation(fields: [driverId], references: [id])
  slot         String
  date         DateTime
  status       TripStatus           @default(ASSIGNED)
  totalBottles Int                  @default(0)
  stops        Int                  @default(0)
  startedAt    DateTime?
  returnedAt   DateTime?
  createdAt    DateTime             @default(now())
  assignments  DeliveryAssignment[]
  @@index([driverId, date, slot])
  @@index([status])
}

// Immutable audit log of every assignment action.
model AssignmentLog {
  id           String           @id @default(cuid())
  action       AssignmentAction
  deliveryId   String?
  driverId     String?
  driver       Driver?          @relation(fields: [driverId], references: [id])
  tripId       String?
  actorId      String?                                // admin/ops user who performed it (null = system)
  actor        User?            @relation(fields: [actorId], references: [id])
  actorRole    String?
  fromDriverId String?                                // for MOVE/REASSIGN
  toDriverId   String?
  bottles      Int?
  note         String?
  meta         Json?
  createdAt    DateTime         @default(now())
  @@index([deliveryId, createdAt])
  @@index([driverId, createdAt])
  @@index([action, createdAt])
}

// ================================================================
// BULK MILK REQUESTS
// Enquiry-based bulk orders for weddings, events, catering, hotels,
// restaurants, festivals, etc. Not an instant checkout — submitted
// requests land in the admin Bulk Orders module for follow-up.
// ================================================================

enum BulkStatus {
  NEW
  CONTACTED
  QUOTATION_SENT
  CONFIRMED
  SCHEDULED
  DELIVERED
  CANCELLED
}

enum BulkEventType {
  WEDDING
  HOUSEWARMING
  BIRTHDAY
  RELIGIOUS
  CATERING
  HOTEL
  RESTAURANT
  CORPORATE
  FESTIVAL
  OTHER
}

enum BulkQtyUnit {
  LITRES
  BOTTLES
}

enum ContactMethod {
  PHONE
  WHATSAPP
  EMAIL
}

model BulkOrderRequest {
  id                     String        @id @default(cuid())
  code                   String        @unique               // human Request ID, e.g. "BULK-7K3M2A"
  // customer details
  fullName               String
  mobile                 String
  email                  String?
  // event details
  eventType              BulkEventType
  eventDate              DateTime
  deliveryTime           String                              // free text, e.g. "7:00 AM"
  deliveryAddress        String
  city                   String
  pincode                String
  // order details
  quantity               Int                                 // > 0 (validated)
  unit                   BulkQtyUnit   @default(LITRES)
  additionalRequirements String?
  // contact + notes
  preferredContact       ContactMethod @default(PHONE)
  specialInstructions    String?
  // workflow
  status                 BulkStatus    @default(NEW)
  assignedToId           String?
  assignedTo             User?         @relation(fields: [assignedToId], references: [id])
  notes                  BulkOrderNote[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  @@index([status, createdAt])
  @@index([eventDate])
}

// Notes + status-change audit trail for a bulk request.
model BulkOrderNote {
  id        String           @id @default(cuid())
  requestId String
  request   BulkOrderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  body      String
  kind      String           @default("note")              // "note" | "status" | "system"
  authorId  String?
  author    User?            @relation(fields: [authorId], references: [id])
  createdAt DateTime         @default(now())
  @@index([requestId, createdAt])
}

// ================================================================
// B2B ORDER MANAGEMENT
// Bulk dairy orders for businesses (hotels, restaurants, cafés, …).
// Admin / Super-Admin only. Sequential Business IDs + order numbers
// via the atomic Counter. Future-ready: branches, credit accounts.
// ================================================================

// Atomic, gapless sequence generator (Business IDs, order numbers, …).
model Counter {
  key   String @id
  value Int    @default(0)
}

// Singleton CMS override for the "UNFOLD PURE" brand-story page (/doodly).
// `data` is a small JSON patch deep-merged over config/brand-story.ts defaults,
// so admins can edit the hero copy, CTA links and QR destination with no deploy.
model BrandStoryConfig {
  id        String   @id @default("default")
  data      Json?
  updatedAt DateTime @updatedAt
}

// ===== Help Center (FAQ knowledge base, admin-editable; analytics) =====
// Seeded once from config/help-center.ts, then fully managed in Admin → Help
// Center (add/edit/delete/reorder/publish) with no code change. `views` powers
// the "most viewed" report. Stable `id` lets a config FAQ and its DB row match.
// ===== Blog (Content → Blog) — the journal published on the customer website =====
enum BlogStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}
model BlogPost {
  id             String     @id @default(cuid())
  slug           String     @unique
  title          String
  excerpt        String?
  content        String?                                   // markdown / rich HTML body
  featuredImage  String?
  author         String?
  categoryName   String?
  tags           String[]
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  readingMinutes Int        @default(1)
  status         BlogStatus @default(DRAFT)
  views          Int        @default(0)
  publishedAt    DateTime?
  scheduledFor   DateTime?
  createdById    String?
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt
  @@index([status, deletedAt])
  @@index([publishedAt])
}

model HelpArticle {
  id        String   @id                              // stable slug (e.g. "what-is-doodly") or cuid for admin-created
  category  String
  question  String
  answer    String
  keywords  String[]
  videoUrl  String?                                   // future: admin-uploaded help video
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  views     Int      @default(0)
  source    String   @default("seed")                 // "seed" | "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, sortOrder])
  @@index([published])
}

// Search analytics — every query is logged with its result count, so the admin
// sees the most-searched keywords AND "unanswered" searches (resultCount = 0).
model HelpSearch {
  id          String   @id @default(cuid())
  term        String
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([term])
  @@index([createdAt])
}

// ===== Global Smart Search (Cmd+K palette) — analytics + trending =====
// Every query/click/no-result is logged so the admin sees most-searched
// keywords, no-result terms, most-clicked targets and a conversion rate.
model SearchEvent {
  id        String   @id @default(cuid())
  kind      String                                    // "query" | "click" | "noresult"
  term      String
  target    String?                                   // clicked item id (kind = click)
  scope     String?                                   // public | customer | admin
  // ---- richer analytics capture (all optional; populated by the client palette) ----
  resultCount Int?                                    // results shown for a query (0 = no-result)
  userId      String?                                 // signed-in searcher (loose label, not a User FK)
  sessionId   String?                                 // client session id (groups a search journey)
  device      String?                                 // "mobile" | "tablet" | "desktop"
  platform    String?                                 // "web" | "ios" | "android" (future)
  durationMs  Int?                                    // client-measured search response time
  createdAt DateTime @default(now())

  @@index([kind, term])
  @@index([createdAt])
  @@index([kind, createdAt])
}

// Admin-managed trending searches (seeded from config TRENDING_DEFAULTS).
model TrendingSearch {
  id        String   @id @default(cuid())
  term      String   @unique
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, sortOrder])
}

enum BusinessType {
  HOTEL
  RESTAURANT
  CAFE
  BAKERY
  SWEET_SHOP
  TEA_STALL
  CATERING
  HOSTEL
  HOSPITAL
  CORPORATE
  OTHER
}

enum PaymentTerm {
  CASH
  CREDIT
  WEEKLY
  MONTHLY
  ADVANCE
}

enum B2BOrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum B2BPaymentStatus {
  PENDING
  PARTIAL
  PAID
  CREDIT
}

model Business {
