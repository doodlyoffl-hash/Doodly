  mobile         String
  altMobile      String?
  email          String?
  // address (Google-Maps assisted → lat/lng stored)
  line1          String
  landmark       String?
  area           String?
  city           String        @default("Vijayawada")
  state          String        @default("Andhra Pradesh")
  pincode        String
  lat            Float?
  lng            Float?
  // GST / billing
  gst            String?
  pan            String?
  billingAddress String?
  // commercials
  paymentTerm    PaymentTerm   @default(CASH)
  discountBps    Int           @default(0)             // default per-business discount (basis points)
  creditLimitPaise Int         @default(0)
  preferredTime  String?
  deliveryNotes  String?
  // lifecycle
  active         Boolean       @default(true)
  deletedAt      DateTime?                             // soft delete (super-admin)
  createdById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orders         BusinessOrder[]
  payments       BusinessPayment[]
  pricing        BusinessPricing[]
  @@index([name])
  @@index([mobile])
  @@index([gst])
  @@index([active, deletedAt])
}

// Per-business negotiated B2B price for a product/variant (+ optional quantity
// slab). The b2bPrice is the source of truth; discount is derived from base.
model BusinessPricing {
  id             String    @id @default(cuid())
  code           String    @unique                 // "B2BP-000001" — sequential
  businessId     String
  business       Business  @relation(fields: [businessId], references: [id])
  productSlug    String
  productName    String                             // snapshot at create time
  variantLabel   String?
  unit           String
  basePricePaise Int                                // catalogue list price at create
  b2bPricePaise  Int                                // negotiated price (source of truth)
  gstBps         Int       @default(0)
  minQty         Int       @default(1)              // quantity-slab floor (1 = all qty)
  effectiveFrom  DateTime  @default(now())
  effectiveUntil DateTime?
  active         Boolean   @default(true)
  deletedAt      DateTime?                          // soft delete (restore-able)
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  history        BusinessPricingHistory[]
  @@index([businessId, productSlug])
  @@index([productSlug])
  @@index([active, deletedAt])
}

// Append-only price-change audit trail (previous → new price/GST, who, when, why).
model BusinessPricingHistory {
  id            String          @id @default(cuid())
  pricingId     String
  pricing       BusinessPricing @relation(fields: [pricingId], references: [id], onDelete: Cascade)
  action        String                              // "created" | "updated" | "deleted" | "restored"
  oldB2bPaise   Int?
  newB2bPaise   Int
  oldGstBps     Int?
  newGstBps     Int
  reason        String?
  byId          String?
  byRole        String?
  createdAt     DateTime        @default(now())
  @@index([pricingId, createdAt])
}

model BusinessOrder {
  id            String           @id @default(cuid())
  code          String           @unique               // "B2B-ORD-2026-000125"
  businessId    String
  business      Business         @relation(fields: [businessId], references: [id])
  status        B2BOrderStatus   @default(PENDING)
  deliveryDate  DateTime
  deliveryTime  String                                 // free text: "5:30 AM", "Custom", …
  deliveryNotes String?
  subtotalPaise Int              @default(0)
  discountPaise Int              @default(0)
  taxPaise      Int              @default(0)
  totalPaise    Int              @default(0)
  paidPaise     Int              @default(0)
  paymentTerm   PaymentTerm
  paymentStatus B2BPaymentStatus @default(PENDING)
  remarks       String?
  createdById   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  items         BusinessOrderItem[]
  payments      BusinessPayment[]
  invoice       BusinessInvoice?
  events        BusinessOrderEvent[]
  @@index([businessId, createdAt])
  @@index([status, deliveryDate])
  @@index([deliveryDate])
  @@index([paymentStatus])
}

// Order Status History / audit timeline — one row per lifecycle event
// (created, status change, payment, invoice, note, edit). Powers the order
// timeline in the UI and a tamper-evident per-order trail.
enum B2BOrderEventType {
  CREATED
  STATUS
  PAYMENT
  INVOICE
  NOTE
  EDIT
}

model BusinessOrderEvent {
  id         String            @id @default(cuid())
  orderId    String
  order      BusinessOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type       B2BOrderEventType
  fromStatus B2BOrderStatus?
  toStatus   B2BOrderStatus?
  note       String?
  byId       String?
  createdAt  DateTime          @default(now())
  @@index([orderId, createdAt])
}

model BusinessOrderItem {
  id             String        @id @default(cuid())
  orderId        String
  order          BusinessOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productSlug    String
  productName    String                                // snapshot at order time
  quantity       Float
  unit           String                                // "Litres" | "KG" | "Bottles"
  unitPricePaise Int
  lineTotalPaise Int
}

model BusinessPayment {
  id           String         @id @default(cuid())
  businessId   String
  business     Business       @relation(fields: [businessId], references: [id])
  orderId      String?
  order        BusinessOrder? @relation(fields: [orderId], references: [id])
  amountPaise  Int
  method       String                                  // cash | upi | bank | adjustment
  reference    String?
  note         String?
  recordedById String?
  createdAt    DateTime       @default(now())
  @@index([businessId, createdAt])
}

enum B2BInvoiceStatus {
  ISSUED
  PARTIAL
  PAID
  VOID
}

model BusinessInvoice {
  id          String           @id @default(cuid())
  number      String           @unique                     // "DOODLY/B2B/2026/00001"
  orderId     String           @unique
  order       BusinessOrder    @relation(fields: [orderId], references: [id])
  businessId  String
  gstPaise    Int              @default(0)
  pdfUrl      String?
  status      B2BInvoiceStatus @default(ISSUED)
  dueDate     DateTime?
  voidedAt    DateTime?
  notes       String?
  terms       String?
  createdById String?
  issuedAt    DateTime         @default(now())
  // --- invoice-email delivery tracking (auto-sent on creation via Resend) ---
  // Latest attempt snapshot; the full per-attempt history lives in
  // BusinessInvoiceEvent rows of type "email" / "email_failed".
  emailStatus     String    @default("PENDING")   // PENDING | SENT | FAILED | SKIPPED
  emailTo         String?                          // address the invoice was sent to
  emailSentAt     DateTime?                         // last successful send
  emailMessageId  String?                          // Resend message id (provider ref)
  emailRetryCount Int       @default(0)             // number of attempts made
  emailError      String?                          // last failure reason (truncated)
  events      BusinessInvoiceEvent[]
  @@index([status])
  @@index([businessId])
  @@index([emailStatus])
}

// Invoice audit trail / status history (created, payment, void, updated, pdf, export).
model BusinessInvoiceEvent {
  id        String          @id @default(cuid())
  invoiceId String
  invoice   BusinessInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String                                          // created | payment | void | updated | pdf | export
  note      String?
  byId      String?
  byRole    String?
  ip        String?
  createdAt DateTime        @default(now())
  @@index([invoiceId, createdAt])
}

// ===================================================================
// Daily Expense Management (Finance → Daily Expenses)
// Admin / Accountant / Super-Admin only. ERP-style: categories,
// approval workflow, partial payments, attachments, audit trail.
// Sequential per-day IDs reuse the Counter model (EXP-YYYYMMDD-NNNN).
// Designed to extend to cost centers / budgets / recurring / vendors
// without schema rewrites (fields are additive).
// ===================================================================

enum ExpensePaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  CHEQUE
  WALLET
  OTHER
}

enum ExpenseStatus {
  PENDING_APPROVAL
  APPROVED
  PAID
  PARTIALLY_PAID
  REJECTED
  CANCELLED
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  expenses  Expense[]
}

model Expense {
  id            String             @id @default(cuid())
  code          String             @unique                  // "EXP-20260701-0001"
  date          DateTime                                    // expense date (not created date)
  title         String
  categoryId    String
  category      ExpenseCategory    @relation(fields: [categoryId], references: [id])
  description   String?
  vendor        String?
  invoiceNo     String?

  paymentMode   ExpensePaymentMode @default(CASH)
  amountPaise   Int                                         // base amount (excl. GST when gstIncluded=false)
  gstIncluded   Boolean            @default(false)
  gstPaise      Int                @default(0)
  totalPaise    Int                                         // amount + (gst when not already included)
  paidPaise     Int                @default(0)

  status        ExpenseStatus      @default(PENDING_APPROVAL)

  // staff name snapshots (selected from existing users; ids kept for reference)
  requestedBy   String?
  approvedBy    String?
  paidBy        String?
  createdById   String?

  notes         String?
  approvedAt    DateTime?
  paidAt        DateTime?
  deletedAt     DateTime?                                   // soft delete
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  attachments   ExpenseAttachment[]
  payments      ExpensePayment[]
  auditLogs     ExpenseAuditLog[]

  @@index([date])
  @@index([status, date])
  @@index([categoryId, date])
  @@index([vendor])
  @@index([deletedAt])
}

model ExpenseAttachment {
  id          String   @id @default(cuid())
  expenseId   String
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  name        String
  kind        String                                        // invoice | receipt | bill | screenshot | pdf | image | other
  url         String?                                       // storage URL (Supabase/Cloudinary in prod)
  mime        String?
  sizeBytes   Int      @default(0)
  uploadedById String?
  createdAt   DateTime @default(now())
}

model ExpensePayment {
  id           String             @id @default(cuid())
  expenseId    String
  expense      Expense            @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  amountPaise  Int
  mode         ExpensePaymentMode @default(CASH)
  reference    String?
  note         String?
  paidBy       String?
  recordedById String?
  createdAt    DateTime           @default(now())

  @@index([expenseId, createdAt])
}

model ExpenseAuditLog {
  id         String   @id @default(cuid())
  expenseId  String
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  action     String                                         // created | updated | approved | rejected | paid | partially_paid | cancelled | deleted
  detail     String?
  fromStatus String?
  toStatus   String?
  actorId    String?
  actorName  String?
  createdAt  DateTime @default(now())

  @@index([expenseId, createdAt])
}

// ============================================================
// System → Support Tickets (customer support desk)
// Actor/customer ids are plain strings (NOT User FKs) so the
// cross-origin dev-bridge actor + non-User customers never
// violate a foreign key. Display fields are denormalised.
// ============================================================
enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id             String         @id @default(cuid())
  number         String         @unique                    // TK-2041
  subject        String
  description    String?
  category       String?                                   // Delivery | Billing | Quality | Bottle | Subscription | Other
  priority       TicketPriority @default(MEDIUM)
  status         TicketStatus   @default(OPEN)
  customerId     String?                                   // User id if known (no FK)
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  orderId        String?                                   // order reference (no FK)
  subscriptionId String?                                   // subscription reference (no FK)
  assigneeId     String?                                   // staff User id (no FK)
  assigneeName   String?
  slaDueAt       DateTime?
  firstResponseAt DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  resolutionNote String?
  mergedIntoId   String?                                   // duplicate merged into this ticket (future-ready)
  tags           String[]
  deletedAt      DateTime?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  messages       SupportMessage[]

  @@index([status, deletedAt])
  @@index([assigneeId])
  @@index([customerId])
  @@index([createdAt])
}

model SupportMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  kind       String        @default("reply")               // reply (customer-facing) | note (internal) | system
  authorId   String?
  authorName String?
  authorRole String?
  body       String
  attachments Json?                                        // [{name,url,size}] future-ready
  createdAt  DateTime      @default(now())

  @@index([ticketId, createdAt])
}

// ============================================================
// System → Chat Support (customer conversations + AI assistant)
// Persists what DOODLY_ASSISTANT previously kept only in
// localStorage. Actor/customer ids are plain strings (no User FK).
// ============================================================
enum ChatStatus {
  ACTIVE
  WAITING
  RESOLVED
  ESCALATED
  CLOSED
}

model ChatSession {
  id            String      @id @default(cuid())
  number        String      @unique                       // CHAT-9F2A1
  customerId    String?                                    // User id if known (no FK)
  customerName  String?
  customerEmail String?
  channel       String      @default("web")               // web | whatsapp (future)
  status        ChatStatus  @default(ACTIVE)
  handledBy     String      @default("AI")                 // AI | Human
  assigneeId    String?                                    // staff id (no FK)
  assigneeName  String?
  csat          Int?                                       // 1..5
  escalated     Boolean     @default(false)
  topics        Json?                                      // { intentId: count }
  lastMessageAt DateTime    @default(now())
  closedAt      DateTime?
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  messages      ChatMessage[]

  @@index([status, deletedAt])
  @@index([lastMessageAt])
  @@index([assigneeId])
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String                                        // user | bot | agent | system | note
  authorName String?
  body       String
  intent     String?
  createdAt  DateTime    @default(now())

  @@index([sessionId, createdAt])
}

// ============================================================
// System → Settings — general-purpose key/value platform config.
// Namespaced keys: general.* , notify.* , security.* — the config
// that had no dedicated home. Company/GST stay in BillingConfig;
// delivery/quality/referral/cashback keep their own singletons.
// ============================================================
model AppSetting {
  key       String   @id                            // e.g. general.brandName, notify.email, security.sessionTimeoutMin
  value     Json                                     // string | number | boolean | object
  updatedAt DateTime @default(now()) @updatedAt
  updatedBy String?
}

// ============================================================
// Content -> Notifications (admin campaigns; reuses per-user Notification for delivery)
// ============================================================
enum NotifCampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

model NotificationCampaign {
  id             String              @id @default(cuid())
  name           String
  audience       String
  channel        NotifChannel
  title          String?
  message        String
  status         NotifCampaignStatus @default(DRAFT)
  recipientCount Int                 @default(0)
  deliveredCount Int                 @default(0)
  sentAt         DateTime?
  createdById    String?
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt

  @@index([status, deletedAt])
  @@index([createdAt])
}

// ============================================================
// Help Center - categories + video guides (persist what DOODLY_HELP kept in localStorage)
// ============================================================
model HelpCategory {
  id        String    @id @default(cuid())
  title     String
  icon      String    @default("info")
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([sortOrder])
}

model HelpVideo {
  id        String    @id @default(cuid())
  title     String
  url       String    @default("")
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([sortOrder])
}

// ============================================================
// Careers → Job Applications (public apply form + admin ATS)
// Resume stored inline as base64 (size-capped) or as an external
// URL; large-scale resume storage → blob store (future config).
// ============================================================
enum AppStatus {
  NEW
  REVIEWING
  SHORTLISTED
  INTERVIEW
  REJECTED
  HIRED
}

model JobApplication {
  id          String    @id @default(cuid())
  refNo       String    @unique                    // APP-#####
  fullName    String
  phone       String
  email       String
  city        String?
  position    String
  experience  String?                              // free text, e.g. "3 years"
  coverLetter String?
  resumeName  String?
  resumeType  String?
  resumeData  String?                              // base64 (small files only)
  resumeUrl   String?                              // alternative link to a resume
  status      AppStatus @default(NEW)
  rating      Int?                                 // 1..5 internal
  notes       String?                              // internal HR notes
  source      String    @default("website")
  ip          String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@index([status, deletedAt])
  @@index([position])
  @@index([createdAt])
}

// ============================================================
// MONTHLY PUZZLE CHALLENGE (Growth → Puzzle Challenge)
// A 6-month campaign: one premium 4×4 slide puzzle per month.
// Unlocks on the 5th, competition closes end-of-month, the winner
// is decided on the 4th of the following month (fewest moves →
// fastest time → earliest completion → secure random) and receives
// a FREE 7-Day Fresh Start subscription (reuses Plan p7 +
// Subscription + SubscriptionEvent + Notification + AuditLog).
// ============================================================
enum PuzzleAttemptStatus {
  STARTED
  COMPLETED
  DISQUALIFIED
}

enum PuzzlePrizeStatus {
  PENDING                                          // winner decided, prize not yet applied
  AWARDED                                          // free subscription created
  PENDING_ADDRESS                                  // winner has no delivery address yet
  FAILED                                           // award errored — admin can retry manually
}

model Puzzle {
  id         String   @id @default(cuid())
  monthIndex Int      @unique                      // 1..6 campaign month
  title      String                                // "The DOODLY Glasses"
  theme      String                                // artwork key: logo|buffalo|bottle|farm|morning|milk
  imageUrl   String?                               // optional admin-uploaded artwork (overrides theme art)
  size       Int      @default(4)                  // 4 → 4×4 (16 tiles)
  unlockAt   DateTime                              // playable from (5th of the month)
  closeAt    DateTime                              // competition ends (end of month)
  winnerAt   DateTime                              // winner announcement (4th of next month)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  attempts   PuzzleAttempt[]
  winner     PuzzleWinner?

  @@index([unlockAt, active])
}

model PuzzleAttempt {
  id          String              @id @default(cuid())
  puzzleId    String
  puzzle      Puzzle              @relation(fields: [puzzleId], references: [id])
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  status      PuzzleAttemptStatus @default(STARTED)
  shuffleSeed String                                // server-issued seed → deterministic board (tamper protection)
  startedAt   DateTime            @default(now())   // server clock (authoritative)
  completedAt DateTime?                             // server clock (authoritative)
  durationMs  Int?                                  // server-computed completedAt − startedAt
  moves       Int?
  device      String?
  browser     String?
  ip          String?

  win         PuzzleWinner?

  @@unique([puzzleId, userId])                      // one participation per customer per puzzle
  @@index([puzzleId, status, moves, durationMs, completedAt])
}

model PuzzleWinner {
  id             String            @id @default(cuid())
  puzzleId       String            @unique          // exactly one winner per puzzle
  puzzle         Puzzle            @relation(fields: [puzzleId], references: [id])
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  attemptId      String            @unique
  attempt        PuzzleAttempt     @relation(fields: [attemptId], references: [id])
  method         String                             // moves | time | timestamp | random — how the tie broke
  decidedAt      DateTime          @default(now())
  prizeStatus    PuzzlePrizeStatus @default(PENDING)
  subscriptionId String?                            // the awarded free 7-day subscription
  notes          String?                            // e.g. manual-award reason

  @@index([userId])
}

// ============================================================
// HR / PAYROLL — Employee profile (1:1 on User), attendance,
// salary structure, advances, payroll, and leave. Reuses User +
// Role for identity/access and AuditLog for the audit trail; all
// money is paise (int). No duplicate identity tables.
// ============================================================
enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}
enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
}
enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  PAID_LEAVE
  SICK_LEAVE
  WEEKLY_OFF
  HOLIDAY
  WFH
}
enum AttendanceSource {
  MANUAL
  GPS
  BIOMETRIC
  QR
}
enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  EMERGENCY
  LOSS_OF_PAY
}
enum LeaveStatus {
  PENDING
  MANAGER_APPROVED
  APPROVED
  REJECTED
  CANCELLED
}
enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}
enum PayslipStatus {
  DRAFT
  FINALIZED
  PAID
}

model EmployeeProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation("EmployeeUser", fields: [userId], references: [id])
  employeeCode       String   @unique
  photoUrl           String?
  altPhone           String?
  dob                DateTime?
  gender             String?
  bloodGroup         String?
  emergencyName      String?
  emergencyPhone     String?
  department         String
  designation        String
  employmentType     EmploymentType   @default(FULL_TIME)
  dateOfJoining      DateTime
  reportingManagerId String?
  reportingManager   EmployeeProfile? @relation("EmpManager", fields: [reportingManagerId], references: [id])
  reports            EmployeeProfile[] @relation("EmpManager")
  workLocation       String?
  status             EmploymentStatus @default(ACTIVE)
  aadhaar            String?
  pan                String?
  drivingLicence     String?
  bankAccount        String?
  ifsc               String?
  bankName           String?
  upiId              String?
  documents          Json?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  salaryStructures   SalaryStructure[]
  attendance         Attendance[]
  leaves             LeaveRequest[]
  leaveBalances      LeaveBalance[]
  advances           SalaryAdvance[]
  payslips           Payslip[]
  @@index([department, status])
  @@index([deletedAt])
}

model SalaryStructure {
  id               String   @id @default(cuid())
  employeeId       String
  employee         EmployeeProfile @relation(fields: [employeeId], references: [id])
  effectiveFrom    DateTime @default(now())
  basicPaise       Int      @default(0)
  hraPaise         Int      @default(0)
  conveyancePaise  Int      @default(0)
  specialPaise     Int      @default(0)
  otherEarnPaise   Int      @default(0)
  ptPaise          Int      @default(0)
  otherDeductPaise Int      @default(0)
  note             String?
  active           Boolean  @default(true)
  createdById      String?
  createdAt        DateTime @default(now())
  @@index([employeeId, effectiveFrom])
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  employee      EmployeeProfile @relation(fields: [employeeId], references: [id])
  date          DateTime
  status        AttendanceStatus @default(PRESENT)
  checkIn       DateTime?
  checkOut      DateTime?
  workedMins    Int      @default(0)
  overtimeMins  Int      @default(0)
  source        AttendanceSource @default(MANUAL)
  note          String?
  correctedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  @@unique([employeeId, date])
  @@index([date])
}

model LeaveRequest {
  id            String   @id @default(cuid())
  code          String   @unique
  employeeId    String
  employee      EmployeeProfile @relation(fields: [employeeId], references: [id])
  type          LeaveType
  startDate     DateTime
  endDate       DateTime
  days          Float
  reason        String?
  attachmentUrl String?
  status        LeaveStatus @default(PENDING)
  managerId     String?
  managerAt     DateTime?
  hrId          String?
  hrAt          DateTime?
  rejectReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  @@index([employeeId, status])
  @@index([status, createdAt])
}

model LeaveBalance {
  id         String   @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])
  year       Int
  type       LeaveType
  allotted   Float    @default(0)
  used       Float    @default(0)
  @@unique([employeeId, year, type])
}

model SalaryAdvance {
  id               String   @id @default(cuid())
  code             String   @unique
  employeeId       String
  employee         EmployeeProfile @relation(fields: [employeeId], references: [id])
  requestDate      DateTime @default(now())
  amountPaise      Int
  reason           String?
  requestedById    String?
  status           AdvanceStatus @default(PENDING)
  approvedById     String?
  approvalDate     DateTime?
  rejectReason     String?
  recoveryMethod   String   @default("SALARY")
  installments     Int      @default(1)
  installmentPaise Int      @default(0)
  recoveredPaise   Int      @default(0)
  remainingPaise   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  recoveries       AdvanceRecovery[]
  @@index([employeeId, status])
}

model AdvanceRecovery {
  id          String   @id @default(cuid())
  advanceId   String
  advance     SalaryAdvance @relation(fields: [advanceId], references: [id])
  payslipId   String?
  payslip     Payslip? @relation(fields: [payslipId], references: [id])
  amountPaise Int
  createdAt   DateTime @default(now())
  @@index([advanceId])
}

model Payslip {
  id                  String   @id @default(cuid())
  code                String   @unique
  employeeId          String
  employee            EmployeeProfile @relation(fields: [employeeId], references: [id])
  month               String
  workingDays         Int      @default(0)
  presentDays         Float    @default(0)
  paidLeaveDays       Float    @default(0)
  absentDays          Float    @default(0)
  overtimeMins        Int      @default(0)
  basicPaise          Int      @default(0)
  hraPaise            Int      @default(0)
  conveyancePaise     Int      @default(0)
  specialPaise        Int      @default(0)
  incentivePaise      Int      @default(0)
  overtimePaise       Int      @default(0)
  bonusPaise          Int      @default(0)
  otherEarnPaise      Int      @default(0)
  advanceRecoverPaise Int      @default(0)
  ptPaise             Int      @default(0)
  otherDeductPaise    Int      @default(0)
  grossPaise          Int      @default(0)
  deductionsPaise     Int      @default(0)
  netPaise            Int      @default(0)
  status              PayslipStatus @default(DRAFT)
  generatedById       String?
  generatedAt         DateTime @default(now())
  paidAt              DateTime?
  pdfUrl              String?
  note                String?
  recoveries          AdvanceRecovery[]
  @@unique([employeeId, month])
  @@index([month, status])
}
