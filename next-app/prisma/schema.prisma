// ----------------------------------------------------------------
// DELIVERY LOGISTICS
// ----------------------------------------------------------------
// (DeliveryZone is defined once above under "Delivery coverage".)

model Driver {                                    // = Delivery Executive (own /delivery login & role)
  id          String     @id @default(cuid())
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id])
  employeeId  String?    @unique                   // "DRV-07" — login via employeeId+password or mobile+OTP
  vehicleNo   String?
  zoneId      String?                              // assigned zone (scopes which deliveries they see)
