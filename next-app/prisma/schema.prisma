// =============================================================
// DOODLY — Database schema (Prisma + PostgreSQL / Supabase)
// -------------------------------------------------------------
// This is the production data model behind the storefront, the
// customer dashboard, the admin ERP, and the delivery app.
// Generate the client with:  npx prisma generate
// Push to Supabase Postgres:  npx prisma migrate dev
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // Supabase pooled connection
  directUrl = env("DIRECT_URL")          // Supabase direct (migrations)
}

// ----------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------
enum Role {
  CUSTOMER
  DELIVERY_EXECUTIVE
  SUPPORT
  OPERATIONS
  PROCUREMENT
  ACCOUNTANT
  INVENTORY
  QUALITY
  MARKETING
  ADMIN
  SUPER_ADMIN
}

// FULL also grants module specials (refund/approve/adjust/assign)
enum PermLevel {
  NONE
  VIEW
  MANAGE
  FULL
}

// The "CMS flip"; Low Stock is DERIVED from stock vs lowStockThreshold, never stored
enum ProductStatus {
  AVAILABLE
  DRAFT
  COMING_SOON
  OUT_OF_STOCK
  DISCONTINUED
  HIDDEN
  ARCHIVED
}

enum VariantType {
  TRIAL
  SUBSCRIPTION
}

enum SubStatus {
  ACTIVE
  PAUSED
  VACATION
  CANCELLED
  COMPLETED
}

// Executive workflow
enum DeliveryStatus {
  SCHEDULED
  ASSIGNED
  ACCEPTED
  PACKED
  OUT_FOR_DELIVERY
  ON_THE_WAY
  REACHED
  DELIVERED
  FAILED
  SKIPPED
}

enum IssueType {
  CUSTOMER_UNAVAILABLE
  WRONG_ADDRESS
  DAMAGED_BOTTLE
  PAYMENT_ISSUE
  PRODUCT_ISSUE
  DELIVERY_FAILED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
}

enum OrderType {
  SUBSCRIPTION
  ONE_TIME
  EXTRA
  SAMPLE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  CASH
}

enum BottleEvent {
  ISSUED
  RETURNED
  LOST
  DEPOSIT_CHARGED
  DEPOSIT_REFUNDED
}

enum TxnType {
  CREDIT
  DEBIT
}

enum NotifChannel {
  SMS
  WHATSAPP
  PUSH
  EMAIL
  IN_APP
}

// ----------------------------------------------------------------
// IDENTITY & PROFILE
// ----------------------------------------------------------------
model User {
  id            String   @id @default(cuid())
  phone         String?  @unique                 // optional once email+password login exists (still used for OTP)
  email         String?  @unique
  name          String?
  role          Role     @default(CUSTOMER)
  passwordHash  String?                          // bcrypt hash — null for OTP-only / not-yet-set accounts
  emailVerified DateTime?                         // set when the email is confirmed
  walletPaise   Int      @default(0)             // store money in paise (int, no float)
  referralCode  String   @unique @default(cuid())
  referredById  String?
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals")
  loyaltyPoints Int      @default(0)              // DOODLY Pure Rewards: available (redeemable) balance — cache of unexpired ledger lots
  loyaltyLifetimeEarned  Int @default(0)          // lifetime points ever earned (drives tier; never decreases)
  loyaltyLifetimeRedeemed Int @default(0)         // lifetime points redeemed to wallet
  dob           DateTime?                         // date of birth (optional) — enables the birthday reward
  notes         String?                          // admin-only notes
  tags          String[]                         // e.g. ["premium","fragile-door"]
  createdAt     DateTime @default(now())

  addresses     Address[]
  subscriptions Subscription[]
  orders        Order[]
  payments      Payment[]
  invoices      Invoice[]
  billings      SubscriptionBilling[]
  paymentRecords PaymentRecord[]
  bottleLedger  BottleLedger[]
  recurringMethods RecurringPaymentMethod[]
  walletTxns    WalletTxn[]
  loyaltyLedger LoyaltyLedger[]                    // DOODLY Pure Rewards: per-lot points ledger
  reviews       Review[]
  notifications Notification[]
  driver        Driver?
  // ---- RBAC / account security ----
  status          UserStatus   @default(ACTIVE)        // active / disabled / locked
  deletedAt       DateTime?                            // soft delete
  forcePwReset    Boolean      @default(false)
  tokenVersion    Int          @default(0)             // bump to instantly revoke all bearer tokens (logout / password change)
  twoFactorOn     Boolean      @default(false)         // enforce for ADMIN / SUPER_ADMIN
  roleAssignments UserRoleAssignment[]                 // secondary roles (multi-role)
  auditLogs       AuditLog[]
  logins          LoginHistory[]
  passwordResets  PasswordResetToken[]                 // outstanding/used password-reset tokens
  assignmentLogs  AssignmentLog[]                      // assignment actions performed by this user (admin/ops)
  bulkAssignments BulkOrderRequest[]                   // bulk enquiries assigned to this staff member
  bulkNotes       BulkOrderNote[]                      // bulk-enquiry notes authored by this user
  trialCashback   TrialCashback?                       // once-per-customer trial-pack cashback ledger
  customerNotes   CustomerNote[]                       // CRM: staff notes on this customer
  customerEvents  CustomerEvent[]                      // CRM: activity / status timeline
  preference      CustomerPreference?                  // CRM: notification + delivery preferences
  puzzleAttempts  PuzzleAttempt[]                      // Monthly Puzzle Challenge participations
  puzzleWins      PuzzleWinner[]                       // Monthly Puzzle Challenge wins
  employeeProfile EmployeeProfile? @relation("EmployeeUser")   // HR: staff employment profile (1:1)
  scheduledAddressChanges ScheduledAddressChange[]     // future-dated delivery address changes requested by this customer
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
}

// ===== RBAC (data-driven so new departments need no code change) =====
model RoleDef {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  isSystem  Boolean  @default(true)
  perms     RolePermission[]
}
model Permission {
  id      String @id @default(cuid())
  module  String
  action  String
  perms   RolePermission[]
  @@unique([module, action])
}
model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         RoleDef    @relation(fields: [roleId], references: [id])
  permissionId String?
  permission   Permission? @relation(fields: [permissionId], references: [id])
  module       String
  level        PermLevel  @default(NONE)
  @@unique([roleId, module])
}
model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roleKey   String
  createdAt DateTime @default(now())
  @@unique([userId, roleKey])
}
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  actorRole String?
  action    String
  target    String?
  ip        String?
  device    String?
  browser   String?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}
model LoginHistory {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  success   Boolean
  ip        String?
  device    String?
  browser   String?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
  @@index([ip, createdAt])            // cross-instance login rate-limit lookups
}

// Single-use, time-boxed password reset. Only the SHA-256 hash of the token is
// stored; the raw token travels in the emailed link, so a DB leak can't reset accounts.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([userId])
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id])
  label        String  @default("Home")
  line1        String
  line2        String?
  city         String
  pincode      String
  lat          Float?
  lng          Float?
  isDefault    Boolean @default(false)
  deliveryNote String?                           // delivery instructions ("ring the bell", "leave at security"), ≤250
  // --- structured last-mile delivery fields (for accurate house/apartment location) ---
  contactName  String?                           // delivery contact name (defaults to the customer)
  contactPhone String?                           // delivery contact number (defaults to the customer)
  altPhone     String?                           // optional alternate contact number
  houseNo      String?                           // House / Flat number  (e.g. "Flat 302", "H.No 12-45", "Villa 18")
  buildingName String?                           // Apartment / Building / House name
  floor        String?                           // Floor ("Ground Floor", "1st Floor", "Independent House")
  street       String?                           // Street / Road name
  area         String?                           // Area / Locality
  state        String?                           // State (e.g. "Andhra Pradesh")
  landmark     String?                           // nearest landmark ("Opposite SBI", "Near Benz Circle")
  block        String?                           // optional — Block / Tower
  wing         String?                           // optional — Wing
  gateNumber   String?                           // optional — Society gate number
  doorColor    String?                           // optional — door colour (visual cue for the executive)
  zoneId       String?
  zone         DeliveryZone? @relation(fields: [zoneId], references: [id])
  subscriptions Subscription[]
  deliveries    Delivery[]               @relation("DeliveryAddress")  // deliveries pinned to this address (history snapshot)
  scheduledAsOld ScheduledAddressChange[] @relation("SACOld")          // scheduled changes moving AWAY from this address
  scheduledAsNew ScheduledAddressChange[] @relation("SACNew")          // scheduled changes moving TO this address
}

// ----------------------------------------------------------------
// CATALOGUE  (admin-editable = the CMS)
// ----------------------------------------------------------------
model Category {
  id          String    @id @default(cuid())
  slug        String    @unique               // "milk","curd","paneer","ghee","sweets"
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  @@index([active, sortOrder])
}

model Product {
  id           String        @id @default(cuid())
  slug         String        @unique              // "milk","curd","paneer","kova","ghee"
  name         String
  category     String?                            // legacy free-text label (kept for back-compat)
  categoryId   String?                            // normalized category (Category model)
  categoryRef  Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description  String                             // short description
  longDesc     String?
  story        String?
  usage        String?
  storage      String?
  ingredients  String?
  allergens    String?
  status            ProductStatus @default(COMING_SOON) // flip to AVAILABLE to launch
  visible           Boolean       @default(true)        // HIDDEN from listings when false
  lowStockThreshold Int           @default(20)          // stock <= this (and > 0) => "Low Stock" badge
  restockDate       DateTime?                           // shown on Out of Stock ("Available again …")
  imageUrl     String?                            // featured image (Cloudinary)
  sortOrder    Int           @default(0)
  ratingValue  Float         @default(0)
  ratingCount  Int           @default(0)
  launchDate   DateTime?                            // a FUTURE date => "Coming Soon" badge
  endDate      DateTime?
  cities       String[]                           // available cities
  featured     Boolean       @default(false)       // "Featured Product" — merchandising flag
  bestSeller   Boolean       @default(false)       // "Best Seller" — recommendation flag
  newArrival   Boolean       @default(false)       // "New Arrival" — recommendation flag
  recommended  Boolean       @default(false)       // "Recommended" — recommendation flag
  relatedSlugs String[]      @default([])          // admin-assigned related product slugs (ordered)
  tags         String[]      @default([])          // free-text PIM tags
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  updatedById  String?                             // staff who last edited (audit "Updated By")
  deletedAt    DateTime?                            // soft delete (excluded from admin/catalogue lists)
  // normalized 1:1 / 1:many detail tables — no JSON blobs
  variants     Variant[]
  images       ProductImage[]
  badges       ProductBadge[]
  pricing      Pricing?
  nutrition    NutritionalInformation?
  quality      QualityParameters?
  seo          SeoMetadata?
  events       ProductEvent[]
}

// Append-only audit / timeline for a product (create, edit, price, stock,
// status, image, variant, seo, delete).
model ProductEvent {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String                                // CREATED|UPDATED|PRICE|STOCK|STATUS|FEATURE|IMAGE|VARIANT|SEO|DELETED|RESTORED|NOTE
  summary   String
  detail    Json?
  byId      String?
  byRole    String?
  ip        String?
  createdAt DateTime @default(now())
  @@index([productId, createdAt])
}

model Variant {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  label       String                              // "500 ml"
  displayName String?                             // "500 ml Daily Bottle"
  sku         String?     @unique
  ml          Int
  type        VariantType @default(SUBSCRIPTION)
  dailyPaise  Int?                                // per-delivery price (subscription)
  fixedPaise  Int?                                // trial: total price (e.g. 20000 = ₹200)
  fixedDays   Int?                                // trial: number of days (e.g. 3)
  stock             Int     @default(0)
  reservedStock     Int     @default(0)            // committed to open orders/subscriptions; available = stock − reserved
  lowStockThreshold Int     @default(20)            // per-variant Low Stock cutoff
  restockDate       DateTime?
  weightG     Int?                                // grams
  barcode     String?                              // EAN/UPC (future-ready)
  active      Boolean     @default(true)
  subItems    SubscriptionItem[]
}

model Plan {
  id            String  @id @default(cuid())
  slug          String  @unique                   // "single","p7","p30","p90"
  name          String                            // "30-Day Morning Ritual"
  days          Int
  discountBps   Int     @default(0)               // basis points: 500 = 5%, 800 = 8%
  badge         String?                           // "Most popular", "Best value"
  description   String?
  autoRenew     Boolean @default(true)
  active        Boolean @default(true)
  subscriptions Subscription[]
}

// ---- normalized product-detail tables (1 row per product) -----
model Pricing {
  id                    String  @id @default(cuid())
  productId             String  @unique
  product               Product @relation(fields: [productId], references: [id])
  mrpPaise              Int
  sellingPaise          Int
  costPaise             Int?
  offerPaise            Int?
  discountBps           Int     @default(0)
  taxBps                Int     @default(0)
  depositPaise          Int     @default(0)       // glass-bottle deposit
  deliveryPaise         Int     @default(0)
  freeDeliveryOverPaise Int     @default(0)
}

model NutritionalInformation {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id])
  fat       String?
  snf       String?
  protein   String?
  calcium   String?
  energy    String?
  carbs     String?
  sugar     String?
  minerals  String?
  vitamins  String?
}

model QualityParameters {
  id             String  @id @default(cuid())
  productId      String  @unique
  product        Product @relation(fields: [productId], references: [id])
  fatPct         String?
  snf            String?
  lactometer     String?
  collectionTemp String?
  storageTemp    String?
  batchNo        String?
  milkType       String?
  animalType     String?
  collectionDate String?
  expiry         String?
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  url        String                              // Cloudinary URL
  alt        String?
  sortOrder  Int     @default(0)
  isFeatured Boolean @default(false)
}

model ProductBadge {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  label     String                              // "Farm Fresh"
  icon      String?
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
}

model SeoMetadata {
  id              String  @id @default(cuid())
  productId       String  @unique
  product         Product @relation(fields: [productId], references: [id])
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  canonicalUrl    String?
  keywords        String[]
}

// ----------------------------------------------------------------
// SUBSCRIPTION ENGINE
// ----------------------------------------------------------------
model Subscription {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  planId          String
  plan            Plan       @relation(fields: [planId], references: [id])
  addressId       String
  address         Address    @relation(fields: [addressId], references: [id])
  status          SubStatus  @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime?
  deliverySlot    String     @default("06:00-08:00")
  nextDeliveryAt  DateTime?
  autoRenew       Boolean    @default(true)
  pausedFrom      DateTime?
  pausedUntil     DateTime?                        // Vacation Mode window
  skipDates       DateTime[]                       // Emergency Skip individual days
  cancelReason    String?                          // why the subscription was cancelled
  notes           String?                          // staff-only internal notes
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now()) @updatedAt

  items           SubscriptionItem[]
  deliveries      Delivery[]
  autopay         AutopaySubscription?
  events          SubscriptionEvent[]
  billings        SubscriptionBilling[]
  addressChanges  ScheduledAddressChange[]             // immediate / future-dated delivery address changes
  @@index([userId, status])
}

// Append-only audit / timeline for a subscription's lifecycle (admin actions,
// status changes, schedule edits, autopay, cashback, refunds, notes).
model SubscriptionEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  type           String                            // CREATED|UPDATED|PAUSED|RESUMED|SKIPPED|CANCELLED|RESCHEDULED|AUTOPAY_ON|AUTOPAY_OFF|CASHBACK|REFUND|NOTE
  summary        String                            // human-readable one-liner
  detail         Json?                             // structured { field: { from, to } } change set
  byId           String?                           // actor user id (null = system)
  byRole         String?                           // actor role at action time
  ip             String?
  createdAt      DateTime     @default(now())
  @@index([subscriptionId, createdAt])
}

// Tenant-friendly delivery address changes — a customer can move a subscription's
// delivery address IMMEDIATELY or from a FUTURE effective date without recreating the
// subscription. On the effective date a cron (or lazy on-read) flips Subscription.addressId
// and repoints future deliveries; completed deliveries keep their pinned Delivery.address.
enum AddressChangeStatus {
  SCHEDULED    // future-dated, not yet applied
  ACTIVE       // applied — this is the subscription's current delivery address
  COMPLETED    // superseded by a later change, or its subscription ended
  CANCELLED    // cancelled before the effective date
}

model ScheduledAddressChange {
  id                     String              @id @default(cuid())
  userId                 String
  user                   User                @relation(fields: [userId], references: [id])
  subscriptionId         String
  subscription           Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  oldAddressId           String
  oldAddress             Address             @relation("SACOld", fields: [oldAddressId], references: [id])
  newAddressId           String
  newAddress             Address             @relation("SACNew", fields: [newAddressId], references: [id])
  effectiveDate          DateTime                              // IST midnight on which the switch applies (immediate = today)
  immediate              Boolean             @default(false)
  status                 AddressChangeStatus @default(SCHEDULED)
  requestedAt            DateTime            @default(now())
  requestedById          String?                               // actor user id (customer self or admin; null = system)
  requestedByRole        String?
  appliedAt              DateTime?
  cancelledAt            DateTime?
  cancelledById          String?
  reminderSentAt         DateTime?                             // 1-day-before reminder dedupe
  scheduledNotifiedAt    DateTime?                             // "change scheduled" confirmation sent
  serviceabilityFailedAt DateTime?                             // apply-time re-check failed → held + alerted
  note                   String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @default(now()) @updatedAt
  @@index([status, effectiveDate])
  @@index([subscriptionId, status])
  @@index([userId, status])
}

// ===== Delivery coverage (serviceable pincodes / zones / waitlist) =====
// Canonical zone model — also used by DELIVERY LOGISTICS (addresses, routes).
model DeliveryZone {
  id        String               @id @default(cuid())
  name      String
  executive String?
  pincodes  ServiceablePincode[]
  addresses Address[]
  routes    Route[]
}
model ServiceablePincode {
  id        String   @id @default(cuid())
  pincode   String   @unique
  area      String
  city      String
  state     String
  zoneId    String?
  zone      DeliveryZone? @relation(fields: [zoneId], references: [id])
  charge    Int      @default(0)                  // delivery charge (₹)
  slot      String   @default("6:00–8:00 AM")
  eta       String?
  enabled   Boolean  @default(true)               // disable without deleting
  deletedAt DateTime?                             // soft-delete (restorable)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}
model WaitlistRequest {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  email     String?
  address   String?
  pincode   String                                // grouped by pincode/area/city in Admin
  createdAt DateTime @default(now())
}

// ===== Delivery Settings — single-row global configuration =====
// Drives the storefront date picker (cut-off, window, advance days, off days,
// holidays) plus delivery pricing + auto-assignment defaults. One row, id
// "singleton". Every change is audited (prev→new) via AuditLog by the route.
model DeliveryConfig {
  id                  String   @id @default("singleton")
  cutoffHour          Int      @default(20)
  cutoffMinute        Int      @default(0)
  slotStart           String   @default("6:00 AM")
  slotEnd             String   @default("8:00 AM")
  availableDays       Int[]    @default([0, 1, 2, 3, 4, 5, 6])   // 0=Sun … 6=Sat
  weekendDelivery     Boolean  @default(true)
  minAdvanceDays      Int      @default(1)
  maxAdvanceDays      Int      @default(30)
  holidays            String[] @default([])                     // ISO YYYY-MM-DD
  blackoutDates       String[] @default([])                     // maintenance / no-delivery
  deliveryChargePaise Int      @default(0)                      // flat charge (0 = free)
  freeAbovePaise      Int      @default(0)                      // free delivery over this order value (0 = off)
  autoAssign          Boolean  @default(true)
  maxPerExecutive     Int      @default(45)                     // max deliveries / executive / trip
  maxBottleCapacity   Int      @default(45)                     // max bottles / trip
  slaPromiseTime      String   @default("07:00")                // Late-delivery SLA: promised-by clock time (HH:mm)
  slaGraceMin         Int      @default(0)                      // grace minutes before a delivery is "late"
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}

// ===== Auto-pay (recurring) =====
enum AutopayStatus {
  ACTIVE
  RETRY
  SUSPENDED
  CANCELLED
  INACTIVE
}

enum AttemptStatus {
  SUCCESS
  FAILED
  PENDING
}

model RecurringPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String                                // "UPI AutoPay" | "Credit Card" | …
  token     String?                               // gateway mandate / token — NEVER raw card data
  label     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  autopays  AutopaySubscription[]
}
model AutopaySubscription {
  id             String       @id @default(cuid())
  gatewaySubId   String?      @unique               // Razorpay subscription id (sub_xxx)
  subscriptionId String       @unique
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  methodId       String?
  method         RecurringPaymentMethod? @relation(fields: [methodId], references: [id])
  status         AutopayStatus @default(ACTIVE)
  nextRenewalAt  DateTime
  amountPaise    Int
  attempts       Int          @default(0)         // resets on success; suspend at the configured retryLimit
  createdAt      DateTime     @default(now())
  renewals       RenewalHistory[]
}
model RenewalHistory {
  id          String   @id @default(cuid())
  autopayId   String
  autopay     AutopaySubscription @relation(fields: [autopayId], references: [id])
  amountPaise Int
  status      AttemptStatus
  chargedAt   DateTime @default(now())
  attempts    PaymentAttempt[]
}
model PaymentAttempt {
  id          String   @id @default(cuid())
  renewalId   String?
  renewal     RenewalHistory? @relation(fields: [renewalId], references: [id])
  status      AttemptStatus
  gatewayRef  String?
  error       String?                             // friendly reason; raw gateway error never shown to customer
  attemptedAt DateTime @default(now())
}

// Singleton delivery config — drives the start-date CUT-OFF rule everywhere
// (web + future mobile, via the same scheduling service). Editable in Admin
// (/admin/delivery-settings); the 8 PM default is configurable, never hardcoded.
// Cut-off is evaluated in the CUSTOMER's local timezone.
model DeliverySettings {
  id               String     @id @default("default")
  cutoffHour       Int        @default(20)                  // 20:00 = 8 PM
  cutoffMinute     Int        @default(0)
  slotStart        String     @default("06:00 AM")
  slotEnd          String     @default("08:00 AM")
  availableDays    Int[]      @default([0,1,2,3,4,5,6])      // 0=Sun … 6=Sat
  weekendDelivery  Boolean    @default(true)
  holidays         DateTime[]                               // no delivery (festivals etc.)
  blackoutDates    DateTime[]                               // maintenance / service unavailable
  minAdvanceDays   Int        @default(1)
  maxAdvanceDays   Int        @default(30)                  // max advance booking
  updatedAt        DateTime   @updatedAt
}

model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  variantId      String
  variant        Variant      @relation(fields: [variantId], references: [id])
  qty            Int          @default(1)          // bottles per delivery
}

// ----------------------------------------------------------------
// ORDERS & DELIVERY
// ----------------------------------------------------------------
model Order {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  type         OrderType     @default(SUBSCRIPTION)
  subtotalPaise Int
  discountPaise Int          @default(0)
  depositPaise  Int          @default(0)           // bottle deposit
  taxPaise      Int          @default(0)           // GST
  deliveryPaise Int          @default(0)
  totalPaise    Int
  // Checkout coupon + wallet (applied server-side; discountPaise stays the plan
  // discount, these are recorded separately for the summary/invoice + rollback).
  couponCode          String?
  couponDiscountPaise Int     @default(0)
  walletAppliedPaise  Int     @default(0)
  status        PaymentStatus @default(PENDING)
  cancelledAt  DateTime?                              // customer/admin cancellation
  createdAt    DateTime      @default(now())
  delivery     Delivery?
  payment      Payment?
  invoice      Invoice?
  items        OrderItem[]
  events       OrderEvent[]
  @@index([userId, createdAt])
  @@index([userId, status])
}

// Line items for a customer order (snapshot of product/variant/price at order time).
model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productSlug    String
  productName    String
  variantLabel   String?
  quantity       Int     @default(1)
  unitPricePaise Int
  lineTotalPaise Int
  @@index([orderId])
}

// Order Status History / fulfilment timeline (created → confirmed → preparing →
// quality check → packed → out for delivery → delivered / cancelled / refund).
enum OrderEventType {
  CREATED
  CONFIRMED
  PAYMENT
  PREPARING
  QUALITY_CHECK
  PACKED
  OUT_FOR_DELIVERY
  ARRIVING
  DELIVERED
  CANCELLED
  REFUND
  NOTE
}

model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      OrderEventType
  title     String
  note      String?
  createdAt DateTime       @default(now())
  @@index([orderId, createdAt])
}

model Delivery {
  id             String         @id @default(cuid())
  subscriptionId String?
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  orderId        String?        @unique
  order          Order?         @relation(fields: [orderId], references: [id])
  addressId      String?                           // delivery address snapshot — pins history so a later address change never rewrites past deliveries
  address        Address?       @relation("DeliveryAddress", fields: [addressId], references: [id])
  date           DateTime                          // the delivery date
  status         DeliveryStatus @default(SCHEDULED)
  routeId        String?
  route          Route?         @relation(fields: [routeId], references: [id])
  driverId       String?
  driver         Driver?        @relation(fields: [driverId], references: [id])
  sequence       Int?                              // stop order on the route
  deliveredAt    DateTime?
  otp            String?                           // delivery OTP
  podPhotoUrl    String?                           // proof-of-delivery (Cloudinary)
  customerRemark String?
  cashCollected  Int            @default(0)        // paise, COD
  bottlesOut     Int            @default(0)        // bottles handed over
  bottlesIn      Int            @default(0)        // empties collected
  bottleEvents   BottleLedger[]
  issues         DeliveryIssue[]
  // ---- Auto-assignment system ----
  bottleCount    Int            @default(1)        // bottles for THIS delivery (capacity unit)
  slot           String?                           // delivery slot key (e.g. "6:00-8:00 AM")
  assignment     DeliveryAssignment?
  queueEntry     AssignmentQueue?
  @@index([date, status])
  @@index([subscriptionId, date])
  @@index([driverId, date])
  @@index([addressId])
}

// ----------------------------------------------------------------
// EMPTY-BOTTLE TRACKING  (per-customer ledger)
// ----------------------------------------------------------------
model BottleLedger {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  deliveryId  String?
  delivery    Delivery?    @relation(fields: [deliveryId], references: [id])
  event       BottleEvent
  qty         Int
  amountPaise Int          @default(0)             // for deposit/lost charges
  note        String?
  createdAt   DateTime     @default(now())
  // Pending bottles for a user = sum(ISSUED) - sum(RETURNED) - sum(LOST)
}

// ----------------------------------------------------------------
// BOTTLE FLEET — reusable glass-bottle asset lifecycle (warehouse side)
// The per-customer relationship lives in BottleLedger above; this tracks
// the physical fleet by capacity × lifecycle stage, with an append-only
// movement ledger that doubles as bottle_movements + bottle_status_history.
// Future-ready: a per-bottle registry + QR/barcode table can hang off this
// once a scanning strategy is chosen (see BottleMovement.note hooks).
// ----------------------------------------------------------------
enum BottleStage {
  AVAILABLE            // sanitised, in warehouse, ready to fill/dispatch
  IN_CIRCULATION       // dispatched — out with drivers / customers
  AWAITING_COLLECTION  // empties at customers, flagged for pickup
  CLEANING             // returned empties in wash / sanitise
  DAMAGED              // out of service, pending write-off
  LOST                 // written off — lost / never returned
}

model BottleStock {
  id         String      @id @default(cuid())
  capacityMl Int                                            // 300 | 500 | 1000
  stage      BottleStage
  qty        Int         @default(0)
  updatedAt  DateTime    @updatedAt
  @@unique([capacityMl, stage])
  @@index([stage])
}

model BottleMovement {
  id         String       @id @default(cuid())
  capacityMl Int
  fromStage  BottleStage?                                   // null = new bottles added to the fleet
  toStage    BottleStage
  qty        Int
  reason     String
  note       String?
  actorRole  String?
  actorId    String?                                        // free-form (may be a cross-origin actor, not a User FK)
  ip         String?
  createdAt  DateTime     @default(now())
  @@index([capacityMl])
  @@index([toStage])
  @@index([createdAt])
}

// ----------------------------------------------------------------
// WALLET / PAYMENTS / INVOICES
// ----------------------------------------------------------------
model WalletTxn {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  type              TxnType                              // CREDIT | DEBIT
  kind              String   @default("adjustment")      // cashback | referral | promo | usage | topup | refund | adjustment | reversal
  amountPaise       Int                                  // always positive; `type` gives direction
  balanceAfterPaise Int      @default(0)                 // wallet balance immediately after this txn
  reference         String   @unique                     // human ref, e.g. "WTX-7K3M2A"
  description       String?
  reason            String                               // legacy short tag ("referral","refund","topup","order")
  subscriptionId    String?
  orderId           String?
  reversedTxnId     String?  @unique                     // if this row reverses another txn, points to it
  createdById       String?                              // admin user id for manual credit/debit (null = system)
  createdAt         DateTime @default(now())
  @@index([userId, createdAt])
  @@index([kind, createdAt])
}

// Idempotency ledger for the Trial Pack cashback — userId UNIQUE guarantees a
// customer can only ever receive the trial cashback once (DB-enforced, race-safe).
model TrialCashback {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  trialOrderId   String?
  subscriptionId String?
  amountPaise    Int
  status         String   @default("CREDITED")          // CREDITED | VOID
  walletTxnId    String?
  creditedAt     DateTime @default(now())
}

// Idempotency ledger for the Referral reward — refereeId UNIQUE guarantees the
// referring customer is rewarded at most once per referred customer (DB-enforced,
// race-safe). Mirrors TrialCashback. Reuses the WalletTxn ledger for the credit.
model ReferralReward {
  id           String   @id @default(cuid())
  referrerId   String                                       // customer who gets the ₹100
  refereeId    String   @unique                             // the new customer they referred (once ever)
  amountPaise  Int
  status       String   @default("CREDITED")                // CREDITED | VOID
  triggerOrderId       String?
  triggerSubscriptionId String?
  walletTxnId  String?
  createdAt    DateTime @default(now())
  @@index([referrerId, createdAt])
}

// Admin-configurable referral programme rules (singleton). The reward, eligibility
// (min plan duration) and on/off switch live here — no code change to tune the policy.
// Future: referral tiers, promo multipliers, partner programmes hang off this.
model ReferralConfig {
  id                String   @id @default("default")
  enabled           Boolean  @default(true)
  rewardAmountPaise Int      @default(10000)             // ₹100 one-time referral reward
  minPlanDays       Int      @default(30)                // eligible from a 30-day (or longer) plan
  maxPerReferrer    Int?                                 // optional cap on rewards per referrer (future)
  updatedAt         DateTime @updatedAt
}

// Admin-configurable cashback rules (singleton). Change without touching code.
model CashbackConfig {
  id                String   @id @default("default")
  enabled           Boolean  @default(true)
  amountPaise       Int      @default(20000)             // ₹200 trial-pack cashback
  eligiblePlanSlugs String[] @default(["p30", "p90"])    // 30-Day Morning Ritual, 90-Day Nourish Plan
  expiryDays        Int?                                 // null = wallet credit never expires
  updatedAt         DateTime @updatedAt
}

// ===== DOODLY Pure Rewards — loyalty programme =====
// Admin-configurable loyalty rules (singleton). Every earning rate, redemption
// ratio, tier threshold and expiry window lives here so the whole policy is
// tunable with no code change. The programme can be globally switched off.
model LoyaltyConfig {
  id                  String   @id @default("singleton")
  enabled             Boolean  @default(true)

  // ---- earning rates (points) ----
  pointsPerHundred    Int      @default(10)               // points per ₹100 spent (paid order value)
  earnRegistration    Int      @default(50)               // one-time on account creation
  earnProfile         Int      @default(25)               // one-time when profile complete (name+email+phone)
  earnSubscribe30     Int      @default(300)              // subscribe to a 30-day (or longer, <90) plan
  earnSubscribe90     Int      @default(1000)             // subscribe to a 90-day (or longer) plan
  earnReferral        Int      @default(500)              // successful referral (referrer), after qualifying sub
  earnBottleReturn    Int      @default(15)               // per glass bottle returned in good condition
  earnRenewal         Int      @default(150)              // monthly subscription renewal
  earnStreak12        Int      @default(200)              // 12 consecutive deliveries without pause
  earnBirthday        Int      @default(250)              // annual birthday reward
  earnAnniversary     Int      @default(1000)             // each DOODLY anniversary
  earnPuzzlePlay      Int      @default(50)               // participate in the monthly puzzle
  earnPuzzleWin       Int      @default(2500)             // win the monthly puzzle (free 7-day plan handled by puzzle engine)
  earnReview          Int      @default(30)               // verified product review (once per delivered order)

  // ---- redemption ----
  redeemPointsPerRupee Int     @default(10)               // 10 points = ₹1 wallet credit
  minRedeemPoints      Int     @default(100)              // minimum points per redemption

  // ---- expiry ----
  expiryDays          Int      @default(365)              // points valid 12 months from the date earned
  remindDays          Int[]    @default([30, 7])          // send expiry reminders this many days before

  // ---- tiers (JSON so thresholds + benefit copy are admin-tunable) ----
  // [{ key, name, min, benefits:[...] }] — tier is derived from lifetime points earned
  tiers               Json?

  // ---- optional bonus campaign (Silver/Gold extra earning) ----
  campaignMultiplier  Float    @default(1.0)              // 1.0 = off; 1.05 = +5% earning during a campaign
  campaignEndsAt      DateTime?

  updatedAt           DateTime @updatedAt
  updatedBy           String?
}

// Append-only points ledger. Each EARN row is a "lot" carrying its own expiry
// (expiresAt) and unconsumed balance (remaining); REDEEM and EXPIRE rows consume
// lots oldest-first (FIFO). `reference` is UNIQUE → every earn/redeem event is
// idempotent (webhook/retry safe), mirroring the WalletTxn ledger.
model LoyaltyLedger {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  type            String                                  // EARN | REDEEM | EXPIRE | ADJUST | REVERSAL
  kind            String                                  // registration|profile|order|subscribe30|subscribe90|referral|bottle|renewal|streak|birthday|anniversary|puzzle_play|puzzle_win|review|redemption|admin_adjust
  points          Int                                     // always positive; `type` gives the direction
  balanceAfter    Int       @default(0)                   // available balance snapshot after this row

  // ---- lot tracking (EARN rows) ----
  expiresAt       DateTime?                               // when this lot expires (EARN only)
  remaining       Int       @default(0)                   // unconsumed points left in this lot (EARN only)

  // ---- links / idempotency ----
  reference       String    @unique                       // e.g. "earn:order:<id>", "earn:reg:<uid>", "redeem:<uid>:<n>"
  description     String?
  orderId         String?
  subscriptionId  String?
  walletTxnId     String?                                 // REDEEM → the WalletTxn that credited the wallet
  reversedId      String?   @unique                       // REVERSAL → the ledger row it reverses
  createdById     String?                                 // admin user id for manual adjust (null = system)
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, type, expiresAt])                      // expiry scan + available-balance calc
  @@index([kind, createdAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  method          PaymentMethod
  amountPaise     Int
  status          PaymentStatus @default(PENDING)
  razorpayOrderId String?
  razorpayPayId   String?
  createdAt       DateTime      @default(now())
}

model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique                     // DOODLY/2026/00001
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  gstPaise    Int      @default(0)
  pdfUrl      String?
  issuedAt    DateTime @default(now())
}

// ================================================================
// SUBSCRIPTION BILLING (Commerce → Subscription Billing)
// The finance layer over Subscriptions: one billing record per
// billing cycle, with a full money breakdown, invoice, payment
// attempts (auto-pay + manual collection + retry), renewal chain,
// and an append-only audit timeline. Wallet movements reuse the
// existing WalletTxn ledger; cashback reuses TrialCashback.
// ================================================================
enum BillingStatus {
  DRAFT
  ISSUED
  RENEWED
  CANCELLED
}
enum BillingPayStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  REFUNDED
}
enum BillingAttemptStatus {
  PENDING
  SUCCESS
  FAILED
}

model SubscriptionBilling {
  id               String       @id @default(cuid())
  code             String       @unique                 // BILL-000001
  subscriptionId   String
  subscription     Subscription @relation(fields: [subscriptionId], references: [id])
  userId           String
  user             User         @relation(fields: [userId], references: [id])

  cycleNumber      Int                                   // 1, 2, 3 … billing cycle index
  billingDate      DateTime     @default(now())
  periodStart      DateTime
  periodEnd        DateTime
  renewalDate      DateTime                              // when the next cycle is due

  planName         String                                // snapshot for history
  planSlug         String
  cycleLabel       String                                // e.g. "30-day cycle"

  billingAmountPaise Int                                 // gross plan value for the cycle
  discountPaise      Int        @default(0)
  gstBps             Int        @default(0)              // GST rate (basis points) applied
  gstPaise           Int        @default(0)
  walletUsedPaise    Int        @default(0)
  totalPaise         Int                                 // final payable = base − discount + gst − wallet
  amountPaidPaise    Int        @default(0)

  autoPay          Boolean      @default(false)
  paymentStatus    BillingPayStatus @default(PENDING)
  billingStatus    BillingStatus    @default(ISSUED)
  attemptsCount    Int          @default(0)

  invoiceNumber    String?      @unique                  // DOODLY/SB/2026/00001
  invoiceIssuedAt  DateTime?
  pdfUrl           String?
  notes            String?

  createdById      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt

  items            BillingItem[]
  attempts         BillingPaymentAttempt[]
  events           BillingEvent[]

  @@unique([subscriptionId, cycleNumber])               // one billing per cycle (no duplicates)
  @@index([userId, billingDate])
  @@index([paymentStatus])
  @@index([billingStatus])
  @@index([renewalDate])
}

model BillingItem {
  id            String              @id @default(cuid())
  billingId     String
  billing       SubscriptionBilling @relation(fields: [billingId], references: [id])
  productName   String
  variantLabel  String
  qty           Int                 @default(1)
  unitPaise     Int                                       // per-delivery price for the cycle line
  lineTotalPaise Int
}

model BillingPaymentAttempt {
  id            String              @id @default(cuid())
  billingId     String
  billing       SubscriptionBilling @relation(fields: [billingId], references: [id])
  attemptNo     Int
  method        PaymentMethod       @default(UPI)
  status        BillingAttemptStatus @default(PENDING)
  amountPaise   Int
  walletPaise   Int                 @default(0)
  reference     String              @unique               // BPA-XXXXXX
  gatewayRef    String?
  failureReason String?
  byId          String?
  byRole        String?
  createdAt     DateTime            @default(now())
  @@index([billingId, attemptNo])
}

model BillingEvent {
  id            String              @id @default(cuid())
  billingId     String
  billing       SubscriptionBilling @relation(fields: [billingId], references: [id])
  type          String                                    // CREATED|PAYMENT|FAILED|RETRY|WALLET|AUTOPAY_ON|AUTOPAY_OFF|RENEWED|INVOICE|REFUND|METHOD|CANCELLED|NOTE
  summary       String
  detail        Json?
  byId          String?
  byRole        String?
  ip            String?
  createdAt     DateTime            @default(now())
  @@index([billingId, createdAt])
}

// Singleton config: GST defaults + auto-pay retry policy + invoice format.
model BillingConfig {
  id                        String   @id @default("default")
  gstBps                    Int      @default(0)           // dairy milk is nil-rated; set per taxable product
  autopayRetryLimit         Int      @default(3)
  autopayRetryIntervalHours Int      @default(24)
  invoicePrefix             String   @default("DOODLY/SB")
  companyName               String   @default("DOODLY")
  gstin                     String?
  updatedAt                 DateTime @updatedAt @default(now())
}

// ================================================================
// PAYMENTS LEDGER (Commerce → Payments)
// The canonical, unified finance ledger across ALL money received:
// order checkout, subscription billing, auto-pay renewals, and
// manual collections. Order `Payment` rows + paid SubscriptionBilling
// rows are synced into this ledger (backfill + forward-sync from the
// Razorpay verify/webhook flow). Wallet movements reuse WalletTxn.
// ================================================================
enum PaymentSource {
  ORDER
  SUBSCRIPTION
  AUTOPAY
  MANUAL
  B2B
}
enum PaymentRecordStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}
enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

model PaymentRecord {
  id               String        @id @default(cuid())
  code             String        @unique                 // PAY-000001
  transactionId    String?       @unique                 // gateway txn / manual reference
  source           PaymentSource @default(ORDER)
  userId           String
  user             User          @relation(fields: [userId], references: [id])

  orderId          String?                                // links (loose — not FK-constrained, ledger spans sources)
  subscriptionId   String?
  billingId        String?
  businessOrderId  String?

  method           PaymentMethod @default(UPI)
  gateway          String        @default("razorpay")     // razorpay | cash | wallet | manual
  amountPaise      Int                                    // gross
  walletUsedPaise  Int           @default(0)
  gstPaise         Int           @default(0)
  discountPaise    Int           @default(0)
  netPaise         Int                                    // collected via gateway/cash (gross − wallet)
  status           PaymentRecordStatus @default(PENDING)
  invoiceNumber    String?
  collectedById    String?                                // staff who recorded a manual payment
  collectedByName  String?

  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  gatewayResponse  Json?
  refundedPaise    Int           @default(0)
  reconciled       Boolean       @default(false)
  notes            String?
  createdById      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt

  refunds          PaymentRefund[]
  attempts         PaymentLedgerAttempt[]
  events           PaymentEvent[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([source])
  @@index([method])
  @@index([createdAt])
}

model PaymentRefund {
  id              String        @id @default(cuid())
  paymentId       String
  payment         PaymentRecord @relation(fields: [paymentId], references: [id])
  amountPaise     Int
  reason          String?
  toWallet        Boolean       @default(false)
  status          RefundStatus  @default(PROCESSED)
  reference       String        @unique                   // RFND-XXXXXX
  gatewayRefundId String?
  byId            String?
  byRole          String?
  createdAt       DateTime      @default(now())
  @@index([paymentId, createdAt])
}

model PaymentLedgerAttempt {
  id          String              @id @default(cuid())
  paymentId   String
  payment     PaymentRecord       @relation(fields: [paymentId], references: [id])
  attemptNo   Int
  status      PaymentRecordStatus
  gatewayRef  String?
  error       String?
  createdAt   DateTime            @default(now())
  @@index([paymentId, attemptNo])
}

// Gateway configuration + readiness (documents the required config points).
model PaymentGateway {
  id                String   @id @default(cuid())
  name              String   @unique                      // "razorpay" | "cash" | "wallet" | "manual"
  label             String
  enabled           Boolean  @default(true)
  mode              String   @default("TEST")              // TEST | LIVE
  keyId             String?                                // public key id (safe to store)
  webhookConfigured Boolean  @default(false)
  supportsRefund    Boolean  @default(true)
  updatedAt         DateTime @default(now()) @updatedAt
}

// Append-only log of received gateway webhooks (signature-verified).
model GatewayWebhook {
  id             String   @id @default(cuid())
  gateway        String   @default("razorpay")
  eventType      String
  signatureValid Boolean
  paymentRef     String?                                   // gateway payment id
  paymentId      String?                                   // linked PaymentRecord id
  processed      Boolean  @default(false)
  error          String?
  createdAt      DateTime @default(now())
  @@index([gateway, createdAt])
}

model PaymentEvent {
  id        String        @id @default(cuid())
  paymentId String
  payment   PaymentRecord @relation(fields: [paymentId], references: [id])
  type      String                                          // CREATED|SUCCESS|FAILED|REFUND|WALLET|INVOICE|RECEIPT|RECONCILE|ATTEMPT|NOTE
  summary   String
  detail    Json?
  byId      String?
  byRole    String?
  ip        String?
  createdAt DateTime      @default(now())
  @@index([paymentId, createdAt])
}

// ----------------------------------------------------------------
// FARMER PROCUREMENT & QUALITY CONTROL
// ----------------------------------------------------------------
model Farmer {
  id           String        @id @default(cuid())
  name         String
  owner        String?                             // owner / contact person
  phone        String
  altPhone     String?
  village      String
  mandal       String?
  district     String?
  state        String?       @default("Andhra Pradesh")
  pincode      String?
  route        String?                             // collection route
  center       String?                             // collection center
  lat          Float?                              // GPS (future-ready)
  lng          Float?
  ratePerLitre Int                                 // paise / litre (farmer pricing)
  notes        String?
  active       Boolean       @default(true)
  deletedAt    DateTime?                           // soft-delete (restorable)
  createdAt    DateTime      @default(now())       // registration date
  updatedAt    DateTime      @default(now()) @updatedAt
  procurements Procurement[]
}

model Procurement {
  id            String       @id @default(cuid())
  farmerId      String
  farmer        Farmer       @relation(fields: [farmerId], references: [id])
  collectedAt   DateTime
  litres        Float
  fatPct        Float
  snfPct        Float
  lactometer    Float?
  temperatureC  Float?
  batchNo       String       @unique
  accepted      Boolean      @default(true)
  amountPaise   Int                                // payable to farmer
  paidAt        DateTime?                          // settlement timestamp (null = due)
  qualityTest   QualityTest?
}

// Configurable quality-acceptance rules (single row, id "singleton").
